# Base image to extend
BASE_IMAGE=quay.io/hummingbird-community/bootc-os:latest

# Enable Fedora Rawhide repo metadata during build (0 or 1)
ENABLE_FEDORA_RAWHIDE_REPO=0

# Optional COPR repository in owner/project format
# Example: COPR_REPO=solopasha/hyprland
COPR_REPO=

# Optional COPR chroot when auto-detection fails on custom bases
# Example values: fedora-43-x86_64, fedora-44-x86_64, epel-10-x86_64
COPR_CHROOT=fedora-43-x86_64

# Resulting local image tag
IMAGE_NAME=localhost/test:latest
